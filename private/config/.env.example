# ==============================================
# NEWSLETTER CONFIGURATION - PRODUCTION SAFE
# ==============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# This file is protected by .htaccess from web access.

# REQUIRED: Admin email address (receives signup notifications)
# Must be a valid email address
NEWSLETTER_ADMIN_EMAIL=admin@example.com

# REQUIRED: Your site name (used in welcome email template)
# Can be anything; appears in email signature
NEWSLETTER_SITE_NAME=My Blog

# REQUIRED: Your site URL (used as CTA link in welcome email)
# Must be a valid HTTPS or HTTP URL (e.g., https://example.com)
# Validated before interpolation into email HTML
NEWSLETTER_SITE_URL=https://example.com

# REQUIRED: SMTP hostname
# Example: smtp.hostinger.com (for Hostinger)
NEWSLETTER_SMTP_HOST=smtp.hostinger.com

# REQUIRED: SMTP port
# Common: 587 (TLS) or 465 (SSL)
# Hostinger typically uses 587 or 465
NEWSLETTER_SMTP_PORT=587

# REQUIRED: SMTP username
# Usually your email address or account username
NEWSLETTER_SMTP_USERNAME=your-email@example.com

# REQUIRED: SMTP password
# For Hostinger, may need to generate an app-specific password:
# Go to Hostinger control panel > Email > App Passwords
# NEVER use special characters that need escaping in values
NEWSLETTER_SMTP_PASSWORD=your-app-password-here

# OPTIONAL: SMTP encryption method
# Options: tls (default), ssl
# Must match your SMTP provider's settings
NEWSLETTER_SMTP_ENCRYPTION=tls

# OPTIONAL: Rate limit - max submissions per IP per hour
# Default: 3
# Prevents spam from a single IP address
NEWSLETTER_RATE_LIMIT_MAX=3

# OPTIONAL: Rate limit time window in seconds
# Default: 3600 (1 hour)
NEWSLETTER_RATE_LIMIT_WINDOW=3600

# OPTIONAL: Duplicate check time window in seconds
# Default: 86400 (24 hours)
# Same email cannot subscribe twice within this window
NEWSLETTER_DUPLICATE_CHECK_WINDOW=86400
